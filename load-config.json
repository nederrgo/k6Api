{
  "service-a": {
    "smoke": {
      "url": "https://httpbin.org/anything",
      "request": {
        "method": "GET",
        "headers": {
          "Accept": "application/json"
        }
      },
      "load": { "vus": 1, "duration": "10s" }
    },
    "spike": {
      "url": "https://httpbin.org/anything",
      "request": {
        "method": "POST",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": { "source": "default-config" }
      },
      "load": { "stages": [ { "duration": "10s", "target": 10 } ] }
    }
  }
}